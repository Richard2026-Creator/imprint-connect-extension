{
  "manifest_version": 3,
  "name": "Pinterest Board Downloader",
  "version": "1.0",
  "description": "Scan the Pinterest board you are viewing, pick the pins you want, and download them as a ZIP.",
  "permissions": ["scripting", "activeTab", "downloads"],
  "host_permissions": [
    "https://*.pinterest.com/*",
    "https://i.pinimg.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pinterest Board Downloader",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
